# --- Survey app DB (uses existing kosca_db Postgres) ---
SURVEY_DB_USER=survey_app
SURVEY_DB_PASSWORD=change-me-strong
DATABASE_URL=postgresql://survey_app:change-me-strong@kosca_db:5432/survey?schema=public

# --- App URLs (set to the actual office-server hostname/IP that employees can reach) ---
APP_URL=http://localhost:3002
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=replace-with-long-random-string

# --- Default seeded users (first boot only; mustChangePassword=true) ---
ADMIN_EMAIL=it@kosca.in
ADMIN_PASSWORD=Kosca@124
HR_EMAIL=hr@kosca.in
HR_PASSWORD=Kosca@124

# --- SMTP (Zoho example; change for any provider) ---
# India: smtp.zoho.in   Global: smtp.zoho.com
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hr@kosca.in
SMTP_PASS=
SMTP_FROM="Kosca Distribution LLP | Survey <hr@kosca.in>"
# Connection pool (parallel sends). Tune up if your SMTP plan allows; tune down if you hit rate limits.
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100

# Used by the daily-reminder cron sidecar (kosca_survey_cron) to authenticate
# its POST to /api/cron/daily-reminders. Generate with: openssl rand -hex 32
CRON_SECRET="change-me-to-32-bytes-of-hex"
